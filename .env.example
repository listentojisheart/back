# Copy to .env for local dev. Railway injects these automatically in production.11

# Environment
ENV=development

# Database (local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tk7

# Redis (local dev)
REDIS_URL=redis://localhost:6379/0

# Security - generate with: openssl rand -hex 32
SECRET_KEY=change-me-for-production-use-openssl-rand-hex-32

# Token lifetime (minutes / days)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=8000

# Frontend CORS (comma-separated for multiple origins, e.g. prod + previews)
FRONTEND_ORIGIN=http://localhost:3000

# Rate limits
USER_DAILY_MESSAGE_LIMIT=20
USER_MONTHLY_MESSAGE_LIMIT=300

# Global circuit breaker (USD/day)
GLOBAL_DAILY_SPEND_CAP_USD=20.0

# Registration gating
INVITE_CODE_REQUIRED=true

# Uploads
MAX_UPLOAD_SIZE_BYTES=20971520
